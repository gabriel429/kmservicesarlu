# Application
APP_NAME=KM Services
# If deploying on Vercel, leave APP_URL empty to auto-use VERCEL_URL
APP_URL=
APP_ENV=production

# Database (use Supabase Postgres or MySQL)
DB_DRIVER=pgsql
DB_HOST=YOUR_SUPABASE_HOST
DB_PORT=5432
DB_NAME=postgres
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD

# Supabase (optional: for Storage, Auth, REST if you integrate later)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_BUCKET=uploads
